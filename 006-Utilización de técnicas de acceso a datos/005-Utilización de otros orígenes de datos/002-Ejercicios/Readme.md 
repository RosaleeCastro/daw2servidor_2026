## 🚀 Plantilla mínima copia-pega

```php
<?php
require 'vendor/autoload.php';
use MongoDB\Client;
use MongoDB\BSON\ObjectId;

$client     = new Client("mongodb://localhost:27017");
$db         = $client->MiBaseDatos;
$collection = $db->MiColeccion;

// INSERT
$collection->insertOne(["campo" => "valor", "numero" => 42]);

// SELECT todos
foreach ($collection->find() as $doc) {
    if (isset($doc["campo"])) echo $doc["campo"];
}

// SELECT uno por campo
$doc = $collection->findOne(["campo" => "valor"]);

// SELECT uno por ID
$doc = $collection->findOne(["_id" => new ObjectId($id)]);

// UPDATE por ID
$collection->updateOne(
    ["_id" => new ObjectId($id)],
    ['$set' => ["campo" => "nuevo valor"]]
);

// UPDATE por campo
$collection->updateOne(
    ["campo" => "valor"],
    ['$set' => ["campo" => "nuevo valor"]]
);

// DELETE por ID
$collection->deleteOne(["_id" => new ObjectId($id)]);

// DELETE por campo
$collection->deleteOne(["campo" => "valor"]);
```